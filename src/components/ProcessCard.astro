---
import decorIcon from '../assets/icons/process-step-decor.svg?url';
import arrowIcon  from '../assets/icons/process-step-arrow.svg?url';

interface Props {
  number: string;
  title: string;
  description: string;
  isLast?: boolean;
}

const { number, title, description, isLast = false } = Astro.props;
---

<div class="process-card">

  <!-- ── Header: hex step decor + arrow ── -->
  <div class="process-card__header">

    <div class="process-card__decor" aria-hidden="true">
      <!-- Rotated hex shape -->
      <div class="process-card__decor-shape">
        <div class="process-card__decor-inner">
          <img src={decorIcon} width="74" height="84" alt="" />
        </div>
      </div>
      <!-- Step number overlaid -->
      <span class="process-card__number">{number}</span>
    </div>

    {!isLast && (
      <div class="process-card__arrow" aria-hidden="true">
        <img src={arrowIcon} width="141" height="20" alt="" />
      </div>
    )}

  </div>

  <!-- ── Copy ── -->
  <div class="process-card__copy">
    <p class="process-card__title">{title}</p>
    <p class="process-card__description">{description}</p>
  </div>

</div>

<style>
  /* ── Card shell ── */

  .process-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4); /* 12px */
    min-width: 0;
    flex: 1;
  }


  /* ── Header row: decor + arrow ── */

  .process-card__header {
    display: flex;
    align-items: flex-end;
    width: 100%;
  }


  /* ── Hex step decor ── */

  .process-card__decor {
    position: relative;
    width: 116px;
    height: 114px;
    flex-shrink: 0;
    margin-inline-end: -5px; /* overlap arrow slightly */
  }

  /* Centering layer */
  .process-card__decor-shape {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Rotated square that gives the hex its diamond orientation */
  .process-card__decor-inner {
    width: 81px;
    height: 81px;
    transform: rotate(-44.5deg) skewX(1deg);
    flex: none;
    line-height: 0;
  }

  .process-card__decor-inner img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: fill;
  }

  /* Step number centred over the hex */
  .process-card__number {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding-bottom: var(--spacing-2);
    font-family: var(--font-display);
    font-size: var(--font-size-3xl);         /* 36px */
    font-weight: var(--font-weight-regular);
    line-height: 1;
    letter-spacing: var(--letter-spacing-normal);
    color: var(--color-text-inverse);
  }


  /* ── Arrow ── */

  .process-card__arrow {
    flex: 1;
    align-self: flex-end;
    line-height: 0;
    overflow: visible;
  }

  .process-card__arrow img {
    display: block;
    width: 100%;
    min-width: 40px;
  }


  /* ── Copy ── */

  .process-card__copy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);            /* 12px */
    padding-inline-start: var(--spacing-gap-default); /* 20px */
  }

  .process-card__title {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);          /* 30px */
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-lg);       /* 150% */
    letter-spacing: var(--letter-spacing-normal);
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  .process-card__description {
    font-family: var(--font-sans);
    font-size: var(--font-size-md);           /* 18px */
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-lg);       /* 150% */
    letter-spacing: var(--letter-spacing-normal);
    color: var(--color-text-primary-muted);
  }
</style>
