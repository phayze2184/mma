---
import logoDesktop from '../assets/logo/logo-desktop-onlight.svg?url';
import logoMobile  from '../assets/logo/logo-mobile-onlight.svg?url';
import Button from './Button.astro';
---

<nav class="navbar">
  <div class="navbar__inner">

    <a href={`${import.meta.env.BASE_URL}/`} class="navbar__logo" aria-label="Medical Marketing Agency">
      <img src={logoDesktop} alt="Medical Marketing Agency" width="173" height="50" class="navbar__logo--desktop" />
      <img src={logoMobile}  alt="Medical Marketing Agency" width="109" height="32" class="navbar__logo--mobile" />
    </a>

    <ul class="navbar__links" id="navbar-links" role="list">
      <li><a href="#servicii"  class="nav-link">Servicii</a></li>
      <li><a href="#de-ce-noi" class="nav-link">De ce noi</a></li>
      <li><a href="#proces"    class="nav-link">Proces</a></li>
      <li><a href="#intrebari" class="nav-link">Întrebări</a></li>
      <li><a href="#contact"   class="nav-link">Contact</a></li>
    </ul>

    <div class="navbar__actions">
      <div class="navbar__cta">
        <Button href="tel:+40732032351">Programează o consultație</Button>
      </div>

      <button
        class="navbar__hamburger"
        id="navbar-toggle"
        aria-controls="navbar-links"
        aria-expanded="false"
        aria-label="Deschide meniul"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </div>
</nav>

<script>
  const toggle = document.getElementById('navbar-toggle')!;
  const links  = document.getElementById('navbar-links')!;

  function closeMenu() {
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Deschide meniul');
    links.classList.remove('navbar__links--open');
    toggle.classList.remove('navbar__hamburger--open');
  }

  toggle.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMenu();
    } else {
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Închide meniul');
      links.classList.add('navbar__links--open');
      toggle.classList.add('navbar__hamburger--open');
    }
  });

  links.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style>
@layer components {
  /* ============================================================
     NAVBAR BASE
     ============================================================ */

  .navbar {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding-block: var(--spacing-5); /* 16px */
    background-color: var(--color-bg-page);
    border-bottom: var(--border-hairline) solid var(--color-border-default);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .navbar__inner {
    max-width: var(--size-container-lg); /* 1200px — desktop default */
    margin-inline: auto;
    padding-inline: var(--spacing-page-inline); /* 20px */
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar__logo {
    flex-shrink: 0; 
    display: flex;
    align-items: center;
  }

  .navbar__logo--mobile { display: none; }

  .navbar__links {
    display: flex;
    gap: var(--spacing-gap-loose); /* 32px */
    align-items: center;
    white-space: nowrap;
  }

  .nav-link {
    color: var(--color-text-primary);
    text-decoration: none;
    position: relative;
    padding-block-end: 2px;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-border-accent-green);
    outline-offset: 4px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-text-accent-green);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 220ms ease;
  }

  .nav-link:hover { color: var(--color-text-accent-green); }
  .nav-link:hover::after { transform: scaleX(1); }

  .navbar__actions {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* ============================================================
     HAMBURGER
     ============================================================ */

  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: var(--spacing-gap-tightest);
    width: var(--size-control-md);  /* 40px */
    height: var(--size-control-md);
    padding: var(--spacing-component-xs); /* 4px */
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }

  .navbar__hamburger:focus-visible {
    outline: 2px solid var(--color-border-accent-green);
    outline-offset: 3px;
    border-radius: var(--radius-md);
  }

  .navbar__hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-primary);
    border-radius: var(--radius-round);
    transition: transform 200ms ease, opacity 200ms ease;
    transform-origin: center;
  }

  /* Open state — top & bottom become an × */
  .navbar__hamburger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .navbar__hamburger--open span:nth-child(2) { opacity: 0; }
  .navbar__hamburger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (prefers-reduced-motion: reduce) {
    .nav-link::after { transition: none; }
    .navbar__hamburger span { transition: none; }
  }

  /* ============================================================
     RESPONSIVE — HAMBURGER (<1024px)
     ============================================================ */

  @media (max-width: 1024px) {
    .navbar__links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background-color: var(--color-bg-page);
      border-bottom: var(--border-hairline) solid var(--color-border-default);
      padding: var(--spacing-gap-tight) var(--spacing-page-inline);
    }

    .navbar__links.navbar__links--open { display: flex; }

    .navbar__links li { width: 100%; }

    .navbar__links .nav-link {
      display: block;
      padding-block: var(--spacing-gap-tight); /* 16px */
    }

    .navbar__hamburger { display: flex; }
    .navbar__cta       { display: none; }
  }

  /* ============================================================
     RESPONSIVE — MOBILE (<576px)
     ============================================================ */

  @media (max-width: 576px) {
    .navbar__inner {
      max-width: 100%;
    }

    .navbar__logo--desktop { 
      display: none; 
    }
    .navbar__logo--mobile { 
      display: block; 
    }

    .navbar__cta { 
      display: none;
    } 
  }
}
</style>
