---
import stepDecorGreen from '../assets/icons/hex-decor-green-48px.svg?url';
import stepDecorAmber from '../assets/icons/hex-decor-amber-48px.svg?url';
import stepBullet from '../assets/icons/process-step-bullet.svg?url';

interface Props {
  number: string;
  variant?: 'green' | 'amber';
  eyebrow: string;
  title: string;
  body: string;
  bullets: string[];
  isLast?: boolean;
}

const {
  number,
  variant = 'green',
  eyebrow,
  title,
  body,
  bullets,
  isLast = false,
} = Astro.props;

const hexSrc    = variant === 'amber' ? stepDecorAmber : stepDecorGreen;
const numberDark = variant === 'amber';
---

<div class:list={['step-card', isLast && 'step-card--last']} style={numberDark ? '--_num-color: var(--color-text-primary)' : undefined}>

  <div class="step-card__header">

    <div class="step-card__decor">
      <div class="step-card__badge">
        <img src={hexSrc} width="74" height="84" alt="" aria-hidden="true" class="step-card__badge-hex" />
        <span class="step-card__number">{number}</span>
      </div>
      <span class="eyebrow">{eyebrow}</span>
    </div>

    {!isLast && (
      <svg class="step-card__arrow" width="80" height="20" viewBox="0 0 141 20" fill="none" aria-hidden="true" focusable="false">
        <path d="M0.5 3.18188H0V4.18188H0.5V3.68188V3.18188ZM140.854 4.03544C141.049 3.84018 141.049 3.52359 140.854 3.32833L137.672 0.146351C137.476 -0.0489113 137.16 -0.0489113 136.964 0.146351C136.769 0.341613 136.769 0.658195 136.964 0.853458L139.793 3.68188L136.964 6.51031C136.769 6.70557 136.769 7.02216 136.964 7.21742C137.16 7.41268 137.476 7.41268 137.672 7.21742L140.854 4.03544ZM0.5 3.68188V4.18188H140.5V3.68188V3.18188H0.5V3.68188Z" fill="currentColor"/>
      </svg>
    )}

  </div>

  <div class="step-card__copy">
    <h4 class="step-card__title">{title}</h4>
    <p class="step-card__body">{body}</p>

    <ul class="step-card__bullets" role="list">
      {bullets.map(bullet => (
        <li class="step-card__bullet">
          <img src={stepBullet} width="16" height="16" alt="" aria-hidden="true" class="step-card__bullet-icon" />
          <span class="body-sm">{bullet}</span>
        </li>
      ))}
    </ul>
  </div>

</div>

<style>
@layer components {
  /* ── Card shell ── */

  .step-card {
    --_arrow-nudge: 4px;
    background-color: var(--color-bg-surface-light);
    border: var(--border-hairline) solid var(--color-border-soft);
    border-radius: var(--radius-card);
    padding-block: var(--spacing-component-lg); /* 40px */
    padding-inline: var(--spacing-component-xl); /* 64px */
    min-height: 400px;

    @media (max-width: 768px) {
      padding-inline: var(--spacing-component-md); /* 24px */
    }
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-snug);

  }

  .step-card:focus-visible {
    outline: 2px solid var(--color-border-accent-green);
    outline-offset: 3px;
  }

  @media (prefers-contrast: more) {
    .step-card { border-color: var(--color-border-strong); }
    .step-card:focus-visible { outline-width: 3px; }
  }

  @media (forced-colors: active) {
    .step-card { border: 1px solid ButtonText; }
    .step-card:focus-visible { outline: 2px solid ButtonText; }
  }

  /* ── Header: badge + eyebrow left, arrow right ── */

  .step-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .step-card__decor {
    display: flex;
    align-items: center;
    gap: var(--spacing-gap-tightest); /* 4px */

    :where(.eyebrow) {
      color: var(--color-text-accent-green);
    }
  }


  /* ── Badge: hexagon + number ── */

  .step-card__badge {
    position: relative;
    width: var(--size-icon-xl);  /* 48px */
    height: var(--size-icon-xl); /* 48px */
    flex-shrink: 0;
  }

  .step-card__badge-hex {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .step-card__number {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--font-size-md); /* 18px */
    font-weight: var(--font-weight-regular);
    line-height: 1;
    padding-bottom: 2px;
    color: var(--_num-color, var(--color-text-inverse));
  }


  /* ── Connector arrow ── */

  .step-card__arrow {
    flex-shrink: 0;
    height: auto;
    color: var(--color-border-default);
    transition: transform 250ms ease, color 250ms ease, stroke-width 250ms ease;

    @media (prefers-reduced-motion: reduce) {
      transition: none;
    }
  }

  .step-card:hover .step-card__arrow {
    transform: translateX(var(--_arrow-nudge));
    color: var(--color-text-accent-gold);
    stroke: currentColor;
    stroke-width: 2px;
  }
 
  /* ── Copy block ── */

  .step-card__copy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight); /* 16px */
  }

  .step-card__title {
    text-transform: uppercase;
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
  }

  .step-card__body {
    color: var(--color-text-primary-muted);
  }


  /* ── Bullet list ── */

  .step-card__bullets {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tighter); /* 8px */
  }

  .step-card__bullet {
    display: flex;
    align-items: center;
    gap: var(--spacing-gap-tightest);

    :where(.body-sm) {
      color: var(--color-text-primary-muted);
    }
  }

  .step-card__bullet-icon {
    flex-shrink: 0;
  }
}
</style>
