---
import SectionHeader from '../../components/SectionHeader.astro';
import ServicesCard from '../../components/ServicesCard.astro';

const services = [
  {
    number: '01',
    title: 'Deschidere clinică/cabinet',
    description: 'Pregătim documentația pentru ONRC, DSP, ISU, Primărie, Colegiul Medicilor și alte instituții relevante.',
    pills: ['Instituții', 'Documente', 'Autorizare'],
    placement: 'top-left' as const,
    href: `${import.meta.env.BASE_URL}/servicii/deschidere-cabinet/`,
  },
  {
    number: '02',
    title: 'Promovare digitală',
    description: 'Campanii Google Ads, Meta Ads și SEO local pentru atragerea pacienților și creșterea vizibilității online.',
    pills: ['Google Ads', 'Meta', 'SEO local'],
    placement: 'top-right' as const,
  },
  {
    number: '03',
    title: 'Website de prezentare',
    description: 'Creăm pagini web clare, profesionale și optimizate pentru încredere, conversie și comunicarea serviciilor medicale.',
    pills: ['UX', 'Website', 'Conversie'],
    placement: 'bottom-left' as const,
  },
  {
    number: '04',
    title: 'Listare produse RX/OTC',
    description: 'Asistență pentru produse RX, OTC, suplimente alimentare, logistică farmaceutică și documentație specifică domeniului.',
    pills: ['RX', 'OTX', 'Suplimente'],
    placement: 'bottom-right' as const,
  },
] satisfies Array<{
  number: string;
  title: string;
  description: string;
  pills: string[];
  placement: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  href?: string;
}>;
---

<section class="services">
  <div class="services__inner">

    <!-- ── Section header ── -->
    <SectionHeader
      eyebrow="Serviciile noastre"
      heading="Ce facem,"
      headingAccent="pe scurt"
      size="large"
      mode="on-light"
    >
      Acoperim partea administrativă și comunicarea pentru afaceri din sănătate. De la primul dosar la primul pacient, lucrăm într-un limbaj clar: al dumneavoastră, al autorităților și al pacientului.
    </SectionHeader>

    <!-- ── Cards grid ── -->
    <div class="services__grid">
      {services.map(s => (
        <ServicesCard
          number={s.number}
          title={s.title}
          description={s.description}
          pills={s.pills}
          placement={s.placement}
          href={s.href}
        />
      ))}
    </div>

  </div>
</section>

<style>
@layer components {
  /* ── Section wrapper ── */

  .services {
    background-color: var(--color-bg-page);
    padding-block: var(--spacing-section-y); /* 120px */
  }

  .services__inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-11); /* 64px */
  }


  /* ── Cards grid ── */

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: 100%;
  }


  /* ── Animation initial states ── */

  .services__inner > :first-child,
  .services__grid > * {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .services__inner > :first-child,
    .services__grid > * {
      opacity: 1;
    }
  }

  /* ── Responsive ── */

  @media (max-width: 768px) {
    .services {
      padding-block: var(--spacing-section-x-compact); /* 48px */
    }

    .services__grid {
      grid-template-columns: 1fr;
    }
  }
}
</style>

<script>
  import { animate, inView, stagger } from 'motion';
  import type { DOMKeyframesDefinition } from 'motion';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const fadeUp = (y: number): DOMKeyframesDefinition => ({ opacity: [0, 1], y: [y, 0] });

    inView('.services__inner', () => {
      const header = document.querySelector('.services__inner > :first-child') as Element;
      const cards  = [...document.querySelectorAll('.services__grid > *')] as Element[];

      animate(header, fadeUp(24), { duration: 0.55, ease: 'easeOut' });
      animate(cards,  fadeUp(32), { duration: 0.5, delay: stagger(0.08, { startDelay: 0.2 }), ease: 'easeOut' });
    }, { amount: 0.15 });
  }
</script>
