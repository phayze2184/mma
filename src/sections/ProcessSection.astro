---
import SectionHeader from '../components/SectionHeader.astro';
import ProcessCard from '../components/ProcessCard.astro';

const steps = [
  {
    number: '01',
    title: 'Apel de descoperire',
    description: 'Discutăm despre nevoile dvs. și identificăm serviciile potrivite pentru afacerea dvs.',
  },
  {
    number: '02',
    title: 'Plan de acțiune',
    description: 'Discutăm despre nevoile dvs. și identificăm serviciile potrivite pentru afacerea dvs. medicală.',
  },
  {
    number: '03',
    title: 'Pregătire și depunere',
    description: 'Pregătim documentația și asigurăm depunerea corectă la instituțiile relevante.',
  },
  {
    number: '04',
    title: 'Autorizație emisă',
    description: 'Monitorizăm procesul și comunicăm cu autoritățile până la finalizarea cu succes.',
    isLast: true,
  },
];
---

<section class="process">
  <div class="process__inner">

    <div class="process__header-wrap">
      <SectionHeader
        eyebrow="Procesul nostru"
        heading="Ce facem,"
        headingAccent="pe scurt"
        size="large"
        mode="on-light"
      >
        Acoperim partea administrativă și comunicarea pentru afaceri din sănătate.
        De la primul dosar la primul pacient, lucrăm într-un limbaj clar:
        al dumneavoastră, al autorităților și al pacientului.
      </SectionHeader>
    </div>

    <div class="process__steps">
      {steps.map(step => (
        <ProcessCard
          number={step.number}
          title={step.title}
          description={step.description}
          isLast={step.isLast ?? false}
        />
      ))}
    </div>

  </div>
</section>

<style>
  .process {
    padding-block: var(--spacing-section-x); /* 120px */
    width: 100vw;
    margin-inline: calc(50% - 50vw);
  }

  .process__inner {
    max-width: var(--size-container-lg); /* 1200px */
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--spacing-page-inline); /* 20px */
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-very-loose); /* 48px */
  }

  .process__steps {
    display: flex;
    gap: var(--spacing-gap-loose); /* 32px */
    align-items: flex-start;
  }

  /* ── Animation initial states ── */

  .process__header-wrap,
  .process__steps > * {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .process__header-wrap,
    .process__steps > * {
      opacity: 1;
    }
  }

  /* ── Responsive ── */

  @media (max-width: 768px) {
    .process {
      padding-block: var(--spacing-section-x-compact); /* 48px */
    }

    .process__steps {
      flex-direction: column;
      gap: var(--spacing-gap-very-loose); /* 48px */
    }

    .process__steps :global(.process-card__arrow) {
      display: none;
    }
  }
</style>

<script>
  import { animate, inView, stagger } from 'motion';
  import type { DOMKeyframesDefinition } from 'motion';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const fadeUp = (y: number): DOMKeyframesDefinition => ({ opacity: [0, 1], y: [y, 0] });

    inView('.process__inner', () => {
      const header = document.querySelector('.process__header-wrap') as Element;
      const cards  = [...document.querySelectorAll('.process__steps > *')] as Element[];

      animate(header, fadeUp(24), { duration: 0.6, ease: 'easeOut' });
      animate(cards,  fadeUp(36), { duration: 0.55, delay: stagger(0.13, { startDelay: 0.15 }), ease: 'easeOut' });
    }, { amount: 0.2 });
  }
</script>
