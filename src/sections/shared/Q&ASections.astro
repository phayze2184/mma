---
import SectionHeader from '../../components/SectionHeader.astro';
import qaImage from '../../assets/images/qa-image.png';
import Accordion from '../../components/Accordion.astro';
import Button from '../../components/Button.astro'
import decorSage from '../../assets/icons/decor-sage-80.svg?url';
import decorAmber from '../../assets/icons/decor-amber-120.svg?url';

const items = [
  {
    question: 'Ce documente sunt necesare pentru deschiderea unui cabinet?',
    answer: 'Documentele necesare variază în funcție de specialitate și județ. În general, sunt necesare cererea de autorizare, documentele de identitate, diplomele medicale, dovada spațiului și autorizațiile sanitare. Vă ghidăm pas cu pas prin tot procesul.',
  },
  {
    question: 'Cum funcționează procesul de consultanță?',
    answer: 'Procesul începe cu un apel de descoperire în care identificăm nevoile dvs. Elaborăm un plan de acțiune personalizat, pregătim documentația necesară și asigurăm comunicarea cu instituțiile relevante până la obținerea autorizațiilor.',
  },
  {
    question: 'Cât durează procesul de deschidere a unui cabinet?',
    answer: 'Durata depinde de complexitatea cazului și de timpii de răspuns ai instituțiilor. Cu documentația pregătită corect de la început, procesul este semnificativ mai rapid și fără erori.',
  },
  {
    question: 'Oferiți suport și pentru farmacii sau depozite de medicamente?',
    answer: 'Da, oferim consultanță completă și pentru farmacii, depozite de medicamente și alte unități farmaceutice, cu experiență în procedurile ANMDMR și cerințele GDP.',
  },
  {
    question: 'Asistați cu listarea de produse RX, OTC sau suplimente alimentare?',
    answer: 'Da, asistăm cu procesele de autorizare și listare pentru medicamente RX, OTC și suplimente alimentare, inclusiv înregistrarea la ANMDMR și cerințele de etichetare.',
  },
];
---

<section class="qa">

  <!-- Row 1: left text + right photo side-by-side -->
  <div class="qa__layout container">

    <div class="qa__left">
      <SectionHeader
         eyebrow="Întrebări și răspunsuri"
         heading="Răspunsuri,"
         headingAccent="fără ocolișuri"
         size="small"
         mode="on-dark"
      >
        Aflați cum lucrăm, ce documente sunt necesare și cum vă putem sprijini în fiecare etapă.
      </SectionHeader>
      <Accordion items={items}/>
    </div>

    <!-- Photo is a direct child of qa__layout — no inner padding constraint -->
    <div class="qa__right-wrapper">
      <div class="qa__photo-group">

        <div class="qa__decor qa__decor--amber" aria-hidden="true">
          <div class="qa__decor-center qa__decor-center--lg">
            <div class="qa__decor-rotate">
              <img src={decorAmber} width="120" height="120" alt="" />
            </div>
          </div>
        </div>

        <div class="qa__decor qa__decor--sage" aria-hidden="true">
          <div class="qa__decor-center qa__decor-center--sm">
            <div class="qa__decor-rotate">
              <img src={decorSage} width="80" height="80" alt="" />
            </div>
          </div>
        </div>

        <div class="qa__photo-wrap">
          <img
            src={qaImage.src}
            width={qaImage.width}
            height={qaImage.height}
            alt="Consultanță medicală"
            class="qa__image"
          />
        </div>

      </div>
    </div>

  </div>

  <!-- Row 2: CTA centered -->
  <div class="qa__cta-wrap container">
    <Button href="tel:+40732032351" variant="tertiary">Discutați cu noi</Button>
  </div>

</section>

<style>
@layer components {
  /* ── Section ── */

  .qa {
    background-color: var(--color-bg-surface-green);
    padding-block: var(--spacing-section-x); /* 120px */
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    overflow: hidden;
  }

  /* ── Row 1: side-by-side layout ── */

  .qa__layout {
    display: flex;
    align-items: start;
    gap: var(--spacing-gap-loose); /* 32px */
  }

  /* ── Left column ── */

  .qa__left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-very-loose); /* 48px */
  }

  /* ── Row 2: CTA centered ── */

  .qa__cta-wrap {
    display: flex;
    justify-content: center;
    padding-block-start: var(--spacing-gap-very-loose); /* 48px */
  }

  /* ── Section header ── */

  .qa__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-tight); /* 16px */
  }

  .qa__heading {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 1.57rem + 2.91vw, 3.75rem); /* 36px → 60px */
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-display); /* 115% */
    letter-spacing: var(--letter-spacing-tight);
    font-style: normal;
  }

  .qa__heading-main   { color: var(--color-text-inverse); }
  .qa__heading-accent { color: var(--color-text-accent-gold-inverse); font-style: italic; }
  .qa__heading-period { color: var(--color-text-inverse); }

  .qa__body {
    font-family: var(--font-sans);
    font-size: var(--font-size-md); /* 18px */
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-lg); /* 150% */
    color: var(--color-text-inverse-muted);
  }

  /* ── Accordion + CTA wrapper ── */

  .qa__accordion-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-gap-very-loose); /* 48px */
    align-items: center;
    width: 100%;
  }


  /* ── Right image panel + decors ── */

  .qa__photo-group {
    position: relative;
    width: 100%;
  }

  .qa__right-wrapper {
    position: relative;
    width: 495px;
    min-height: 480px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    padding-top: 40px;
  }

  .qa__photo-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 3 / 4;
    max-height: 660px;
    border-radius: var(--radius-card); /* 16px */
    overflow: hidden;
    box-shadow: var(--elevation-4);
  }

  .qa__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    z-index: 1;
  }

  /* ── Hex decorations ── */

  .qa__decor {
    position: absolute;
    top: -44px;
    pointer-events: none;
    user-select: none;
  }

  .qa__decor--amber {
    right: -72px;
    z-index: 2;
  }

  .qa__decor--sage {
    right: 5px;
    z-index: 0;
  }

  .qa__decor-center {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qa__decor-center--lg {
    width: 170px;
    height: 170px;
  }

  .qa__decor-center--sm {
    width: 113px;
    height: 113px;
  }

  .qa__decor-rotate {
    flex: none;
    line-height: 0;
  }

  /* ── Animation initial states ── */

  .qa__left > *,
  .qa__right-wrapper {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .qa__left > *,
    .qa__right-wrapper {
      opacity: 1;
    }
  }

  /* ── Responsive ── */

  @media (max-width: 1024px) {
    .qa__right-wrapper {
      width: 360px;
      height: 520px;
    }
  }

  @media (max-width: 768px) {
    .qa {
      padding-block: var(--spacing-section-x-compact); /* 48px */
    }

    /* Strip layout padding → photo inherits full 100vw width of .qa */
    .qa__layout {
      flex-direction: column;
      gap: 0;
      padding-inline: 0;
      max-width: 100%;
    }

    /* Restore side padding for text only */
    .qa__left {
      padding-inline: var(--spacing-component-sm); /* 16px — matches mobile container padding */
      padding-block-end: var(--spacing-gap-very-loose);
    }

    .qa__right-wrapper {
      width: 100%;
      height: 280px;
      padding-top: 0;
      min-height: unset;
    }

    .qa__photo-wrap {
      border-radius: 0;
    }

    .qa__decor {
      display: none;
    }
  }
}
</style>

<script>
  import { animate, inView, stagger } from 'motion';
  import type { DOMKeyframesDefinition } from 'motion';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const fadeUp    = (y: number): DOMKeyframesDefinition => ({ opacity: [0, 1], y: [y, 0] });
    const slideInRight = (): DOMKeyframesDefinition => ({ opacity: [0, 1], x: [36, 0] });

    inView('.qa__layout', () => {
      const leftItems = [...document.querySelectorAll('.qa__left > *')] as Element[];
      const image     = document.querySelector('.qa__right-wrapper') as Element;

      animate(leftItems, fadeUp(24), { duration: 0.55, delay: stagger(0.13), ease: 'easeOut' });
      animate(image, slideInRight(), { duration: 0.7, delay: 0.2, ease: 'easeOut' });
    }, { amount: 0.2 });
  }
</script>
